{
  "cli": {
    "version": ">= 16.24.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": false,
      "distribution": "internal",
      "channel": "development",  
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_SERVER_URL": "@EXPO_PUBLIC_SERVER_URL",
        "EXPO_PUBLIC_OPENAI_API_KEY": "@EXPO_PUBLIC_OPENAI_API_KEY",
        "EXPO_PUBLIC_WHISPER_API_KEY": "@EXPO_PUBLIC_WHISPER_API_KEY"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",  
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_SERVER_URL": "@EXPO_PUBLIC_SERVER_URL",
        "EXPO_PUBLIC_OPENAI_API_KEY": "@EXPO_PUBLIC_OPENAI_API_KEY",
        "EXPO_PUBLIC_WHISPER_API_KEY": "@EXPO_PUBLIC_WHISPER_API_KEY"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",  
      "android": {
        "buildType": "apk",
        "distribution": "internal",
        "abi": ["arm64-v8a"]
      },
      "env": {
        "EXPO_PUBLIC_SERVER_URL": "@EXPO_PUBLIC_SERVER_URL",
        "EXPO_PUBLIC_OPENAI_API_KEY": "@EXPO_PUBLIC_OPENAI_API_KEY",
        "EXPO_PUBLIC_WHISPER_API_KEY": "@EXPO_PUBLIC_WHISPER_API_KEY"
      }
    }
  },
  "submit": {
    "production": {}
  }
}